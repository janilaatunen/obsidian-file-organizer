{
  "name": "obsidian-file-organizer",
  "version": "1.1.5",
  "description": "Organize files by tags, file types, and filename patterns",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "./node_modules/.bin/tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "deploy": "cp main.js manifest.json ~/Obsidian/Codex/.obsidian/plugins/file-organizer/",
    "build:deploy": "npm run build && npm run deploy"
  },
  "keywords": [
    "obsidian",
    "obsidian-plugin",
    "file-organizer",
    "automation"
  ],
  "author": "Jani Laatunen",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^24.10.1",
    "builtin-modules": "^5.0.0",
    "esbuild": "^0.27.0",
    "obsidian": "^1.10.3",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3"
  }
}
